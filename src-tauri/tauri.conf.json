{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Refsu",
  "version": "1.1.0",
  "identifier": "dev.vilaz.refsu",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Refsu",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://refsu.vilaz.dev https://osu.ppy.sh"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBQUYxMzRBOUFBQzI2OEMKUldTTUpxeWFTaE92T3N3OTFwRFcwWXV1L1A3d1JhZ0Q5VkEvRjYzRTJkTVZtSkJVWURPbUNJakoK",
      "endpoints": [
        "https://refsu.vilaz.dev/updates"
      ]
    },
    "sql": {
      "preload": [
        "sqlite:refsu_database.db"
      ]
    },
    "deep-link": {
      "mobile": [
        {
          "host": "refsu.vilaz.dev",
          "pathPrefix": [
            "/app-link"
          ]
        }
      ],
      "desktop": {
        "schemes": [
          "refsu"
        ]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}